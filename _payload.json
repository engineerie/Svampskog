,"path":66,"stem":67},"Kanteffekt","/skogsskotsel/markorer/kanteffekt","2.skogsskotsel/markorer/kanteffekt",{"title":69,"path":70,"stem":71},"Naturvårdssvampar","/skogsskotsel/markorer/naturvardsarter","2.skogsskotsel/markorer/naturvardsarter",{"title":73,"path":74,"stem":75},"Hänsynsträd","/skogsskotsel/markorer/retention","2.skogsskotsel/markorer/retention",{"title":77,"path":78,"stem":79},"Plockhuggna träd","/skogsskotsel/markorer/rottackebladning","2.skogsskotsel/markorer/rottackeBladning",{"title":81,"path":82,"stem":83},"Skärmträd","/skogsskotsel/markorer/rottackeskarmtrad","2.skogsskotsel/markorer/rottackeSkarmtrad",{"title":85,"path":86,"stem":87},"Fröträd","/skogsskotsel/markorer/seedtree","2.skogsskotsel/markorer/seedTree",{"title":89,"path":90,"stem":91},"Plantor och små träd","/skogsskotsel/markorer/smaplantor","2.skogsskotsel/markorer/smaplantor",{"title":93,"path":94,"stem":95},"Planterade plantor","/skogsskotsel/markorer/tradplantor","2.skogsskotsel/markorer/tradplantor",{"id":97,"title":98,"description":99,"entries":100,"extension":123,"meta":124,"stem":125,"__hash__":126},"glossary/5.glossary.yml","Ordlista","Grundbegrepp inom svamp och skogsekologi.",[101,107,112,115,120],{"term":102,"definition":103,"aliases":104},"Mykorrhiza","Symbios mellan svamp och växtrötter där svampen hjälper växten att ta upp vatten och näring, och får kolhydrater tillbaka.",[105,106],"ektomykorrhiza","svamprot",{"term":108,"definition":109,"aliases":110},"Hyfer","Mikroskopiskt tunna svamptrådar som bygger upp svampens mycel.",[111],"svamptrådar",{"term":113,"definition":114},"Mycel","Nätverk av hyfer som utgör den största delen av svampen i mark eller ved.",{"term":116,"definition":117,"aliases":118},"Fruktkropp","Den synliga delen av svampen som bildar och sprider sporer.",[119],"svampkropp",{"term":121,"definition":122},"Kalhygge","En yta där nästan alla träd har avverkats, vilket kraftigt förändrar mikroklimat och markförhållanden.","yml",{},"5.glossary","2OMXumbXGEdG5_LRHyGGrqW4JlEr3RWFimVuLZJGW10",{"id":128,"title":129,"body":130,"description":131,"extension":123,"financing":132,"hero":156,"meta":178,"navigation":44,"path":179,"press":180,"sections":193,"seo":211,"stem":212,"timeline":213,"__hash__":239},"index/0.index.yml","Svampskog",null,"Svampskog.se är en webbapplikation där du kan utforska vilka mykorrhizasvampar som kan finnas i olika skogar och se hur de reagerar vid skogsbruksåtgärder.",{"headline":133,"logos":134,"notes":150},"Projektet har finansierats av SLU och Skogssällskapet och med stöd från Skogsstyrelsen och EU.",[135,139,143,147],{"src":136,"alt":137,"height":138},"/images/logo/slu_logo_webb.png","SLU",60,{"src":140,"alt":141,"height":142},"/images/logo/skogssallskapet_logo.png","Skogssällskapet",50,{"src":144,"alt":145,"height":146},"/images/logo/Skogsstyrelsen_logo.png","Skogsstyrelsen",80,{"src":148,"alt":149,"height":146},"/images/logo/EU_Logo.png","EU",[151,152,153,154,155],"Verktyget är utvecklat med data från Markinventeringen, SLU riksskogstaxeringen och SLU Artdatabanken.","Referensgrupp: Representanter från Bitzner, Skogforsk, Skogsstyrelsen, SLU-Artdatabanken, Sveaskog och Södra Skogsägarna.","Ansvarig för projektet och för informationsinnehåll: Anders Dahlberg, SLU","Webb och konceptutveckling: Jacob Bertilsson","Kontakt: Anders Dahlberg, anders.dahlberg@slu.se",{"title":157,"description":158,"links":159,"headline":172,"mykorrhiza":175},"Svampar och skogsskötsel","Utforska mykorrhizasvampar i svenska skogar och se hur de påverkas av skogsskötsel.",[160,168],{"label":161,"icon":162,"trailing":44,"to":163,"target":164,"size":165,"color":166,"variant":167},"Svampar","i-lineicons-mushroom-1","/mykorrhizasvampar","","xl","neutral","solid",{"label":169,"icon":170,"trailing":44,"to":48,"target":164,"size":165,"color":166,"variant":171},"Skogsskötsel","i-hugeicons-tree-06","soft",{"label":164,"to":173,"icon":164,"color":174},"/svampkunskap","secondary",{"title":176,"body":177},"Mykorrhiza är en 500 miljoner år gammal symbios mellan växter och svampar.","Symbiosen innebär att mykorrhizasvamparna får sin energi från träden och i utbyte sköter de om trädens näringsförsörjning.",{},"/",{"title":181,"description":182,"items":183},"Webbinarier","Fördjupa dig i svampar och skogsbruk och ställ dina frågor direkt till forskare.",[184],{"title":185,"publication":137,"publicationDate":186,"url":187,"icon":188,"description":189,"badge":190},"Webbinarium om Svampskog","Vår 2026","https://www.slu.se/om-slu/organisation/fakulteter/fakulteten-for-skogsvetenskap/samverkan/kompetensutveckling-for-ett-hallbart-skogsbruk/se-svampen-i-din-skog/","i-heroicons-calendar-date-range","Lär dig mer om skogens mykorrhizasvampar och hur skogsskötsel påverkar dem - och få en genomgång av hur du använder funktionerna i webbappen Svampskog.",{"label":191,"color":192},"Anmäl intresse","info",[194,203],{"title":195,"description":196,"headline":161,"id":197,"links":198,"orientation":201,"reverse":202},"Utforska svampar i svenska skogar","Baserat på DNA-analyser av svampmycel i jordprover och vår samlade kunskap om var olika arters fruktkroppar förekommer.","svampar",[199],{"label":200,"to":163,"icon":162,"color":166,"variant":167,"size":165},"Gå till svampar","horizontal",true,{"title":204,"description":205,"headline":169,"id":206,"src":207,"links":208,"orientation":201,"reverse":44},"Hur påverkar olika skogsskötsel svampar?","Utifrån sammanställd forskning visar vi hur trakthyggesbruk och hyggesfria metoder kan påverka mykorrhizasvampar under en skogsgeneration.","skogsbruk","/images/Landing/Stock Photo 563535222.jpeg",[209],{"label":210,"to":48,"icon":170,"color":166,"variant":167,"size":165},"Gå till skogsskötsel",{"title":129,"description":131},"0.index",{"title":214,"description":215,"items":216},"Kommande innehåll","Svampskog.se vidareutvecklas stegvis med nya funktioner och material.",[217,222,227,230,235],{"date":218,"title":219,"description":220,"icon":221},"Vår 2025","Mjuklansering","Mjuklansering i samband med Flora och faunavårds-konferansen 9 april. Ett öppet webbinarium om att använda Svampskog hölls den 23 april.","i-hugeicons-plant-01",{"date":223,"title":224,"description":225,"icon":226},"Sommar 2025","Mobilanpassning","Hemsidan utvecklas löpande och mobilanpassas under sommaren 2025.","i-heroicons-sun",{"date":228,"title":169,"description":229,"icon":170},"Höst 2025","Information om skogsskötsel färdigställs och lanseras.",{"date":231,"title":232,"description":233,"icon":234},"Vinter 2025/26","Svampkunskap","Modul för svampkunskap med tillhörande lärarhandledning läggs upp på svampskog.se","i-hugeicons-book-03",{"date":186,"title":236,"description":237,"icon":238},"Webbinarium","Webbinarium om svampar, skogssbruk och funktionerna på svampskog.se hålls.","i-hugeicons-presentation-line-chart-01","cdRywn8-GcNv3REw6eec8RNWd-EagsGBSU59CZPXsZg",[241,269,315,354,388],{"id":242,"title":243,"body":244,"description":250,"extension":254,"icon":255,"image":256,"impactLabel":130,"impactTone":130,"impactValue":257,"index":257,"meta":258,"methodId":259,"methodTitle":260,"navigation":261,"path":262,"section":263,"sectionIndex":264,"sectionTitle":260,"seo":265,"shortdescription":266,"stem":267,"type":130,"__hash__":268},"skotselmetodSections/2.skogsskotsel/metoder/0.ingen_atgard/0.om_metoden.md","OmMetoden",{"type":245,"value":246,"toc":251},"minimark",[247],[248,249,250],"p",{},"Beståndet lämnas för fri utveckling tills vidare, till exempel som en frivillig naturvårdsavsättning eller en skog med områdesskydd.",{"title":164,"searchDepth":252,"depth":252,"links":253},2,[],"md","i-lucide-trees","images/metoder/ingen_åtgärd.png",0,{},"ingenatgard","Inga åtgärder","test","/skogsskotsel/metoder/ingen_atgard/om_metoden","om_metoden",1,{"title":243,"description":250},"Orörd skog","2.skogsskotsel/metoder/0.ingen_atgard/0.om_metoden","_Vy9ecvrIAfUmbileffbH05EjzPz_cCyTJSxlcu_WX8",{"id":270,"title":243,"body":271,"description":303,"extension":254,"icon":304,"image":305,"impactLabel":130,"impactTone":130,"impactValue":257,"index":264,"meta":306,"methodId":307,"methodTitle":308,"navigation":202,"path":309,"section":263,"sectionIndex":257,"sectionTitle":308,"seo":310,"shortdescription":311,"stem":312,"type":313,"__hash__":314},"skotselmetodSections/2.skogsskotsel/metoder/1.bladning/0.om_metoden.md",{"type":245,"value":272,"toc":301},[273,276,283,289,295],[248,274,275],{},"Blädning innebär ofta uttag om 20-30 procent av virkesvolymen med intervall på 15-30 år.",[277,278,280],"icon-bullet",{"icon":279},"i-lineicons-trees-3",[248,281,282],{},"Avverkning görs med målet att skapa och bibehålla en fullskiktad skog, det vill säga en skog med träd i alla storlekar.",[277,284,286],{"icon":285},"i-heroicons-cloud",[248,287,288],{},"Blädning fungerar bäst med skuggtåliga trädslag, som gran och bok.",[277,290,292],{"icon":291},"i-carbon-soil-moisture-field",[248,293,294],{},"Marken måste vara tillräckligt bördig, för att plantor och småträd ska klara att växa i det slutna beståndet.",[277,296,298],{"icon":297},"i-material-symbols-light-water-drop-outline",[248,299,300],{},"Blädning lämpar sig i skogar där man vill bevara en fuktigare och mer skyddad miljö.",{"title":164,"searchDepth":252,"depth":252,"links":302},[],"Blädning innebär ofta uttag om 20-30 procent av virkesvolymen med intervall på 15-30 år. Avverkning görs med målet att skapa och bibehålla en fullskiktad skog, det vill säga en skog med träd i alla storlekar.","i-tabler-christmas-tree-off","images/metoder/blädning.png",{},"bladning","Blädning","/skogsskotsel/metoder/bladning/om_metoden",{"title":243,"description":303},"Enstaka träd avverkas","2.skogsskotsel/metoder/1.bladning/0.om_metoden","Hyggesfritt","I1LAb59OWt66EIFB0UqSswCSWawA7uRmKisU5MFitR8",{"id":316,"title":243,"body":317,"description":321,"extension":254,"icon":344,"image":345,"impactLabel":130,"impactTone":130,"impactValue":257,"index":252,"meta":346,"methodId":347,"methodTitle":348,"navigation":202,"path":349,"section":263,"sectionIndex":264,"sectionTitle":348,"seo":350,"shortdescription":351,"stem":352,"type":313,"__hash__":353},"skotselmetodSections/2.skogsskotsel/metoder/2.luckhuggning/0.om_metoden.md",{"type":245,"value":318,"toc":342},[319,322,328,334],[248,320,321],{},"Luckhuggning innebär att träd avverkas i luckor med 20-50 m storlek som motsvarar luckor på 500-2 500 m². När ny skog vuxit upp kan luckorna utvidgas eller nya luckor tas upp i beståndet.",[277,323,325],{"icon":324},"i-bx-bxs-chess",[248,326,327],{},"Systematiska former av luckhuggning är schackrutehuggning och kanthuggning.",[277,329,331],{"icon":330},"i-material-symbols-forest-outline",[248,332,333],{},"Luckhuggning fungerar även i enskiktad granskog.",[335,336],"u-alert",{"className":337,"color":339,"title":340,"variant":341},[338],"my-6","tertiary","Luckor större än 2 500 m² räknas som hyggen enligt Skogsstyrelsens definition.","subtle",{"title":164,"searchDepth":252,"depth":252,"links":343},[],"i-pixelarticons:chess","images/metoder/luckhuggning.png",{},"luckhuggning","Luckhuggning","/skogsskotsel/metoder/luckhuggning/om_metoden",{"title":243,"description":321},"Mindre ytor kalavverkas","2.skogsskotsel/metoder/2.luckhuggning/0.om_metoden","SaPemNzAhgcJn4aRMv7Uc-3mOcY9Iz29O9EpJTT0R_8",{"id":355,"title":243,"body":356,"description":360,"extension":254,"icon":378,"image":379,"impactLabel":130,"impactTone":130,"impactValue":257,"index":380,"meta":381,"methodId":382,"methodTitle":383,"navigation":202,"path":384,"section":263,"sectionIndex":264,"sectionTitle":383,"seo":385,"shortdescription":383,"stem":386,"type":313,"__hash__":387},"skotselmetodSections/2.skogsskotsel/metoder/3.skarmtrad/0.om_metoden.md",{"type":245,"value":357,"toc":376},[358,361,367,372],[248,359,360],{},"Överhållen skärm innebär att antalet lämnade skyddande skärmträd är fler än vid en vanlig fröträdsställning och att de sparas längre än vid normalt skärmskogsbruk. Skärmträden avvecklas successivt i flera steg medan trädplantor etableras och växer till.",[277,362,364],{"icon":363},"i-streamline-tree-3",[248,365,366],{},"Tall och bok fungerar bra att föryngra under överhållen skärm. Gran är vindkänsligare och lämpar sig därför sämre.",[277,368,369],{"icon":226},[248,370,371],{},"Överhållen skärm kan vara ett bra val i skogar med naturvärden som vill ha ljus och värme.",[335,373],{"className":374,"color":339,"title":375,"variant":341},[338],"För att räknas som en hyggesfri metod enligt Skogsstyrelsens definition måste minst 25 träd per hektar lämnas att ingå i det nya beståndet.",{"title":164,"searchDepth":252,"depth":252,"links":377},[],"i-lucide-lab-trees-forest","images/metoder/skärm.png",3,{},"skarmtrad","Överhållen skärm","/skogsskotsel/metoder/skarmtrad/om_metoden",{"title":243,"description":360},"2.skogsskotsel/metoder/3.skarmtrad/0.om_metoden","FcgvdIcvzQeLxBTsLxsVPwZ4EuJcv6VrL2wvqWtQupA",{"id":389,"title":243,"body":390,"description":409,"extension":254,"icon":410,"image":411,"impactLabel":130,"impactTone":130,"impactValue":257,"index":412,"meta":413,"methodId":414,"methodTitle":415,"navigation":202,"path":416,"section":263,"sectionIndex":264,"sectionTitle":415,"seo":417,"shortdescription":418,"stem":419,"type":130,"__hash__":420},"skotselmetodSections/2.skogsskotsel/metoder/4.trakthygge/0.om_metoden.md",{"type":245,"value":391,"toc":407},[392,395,401],[248,393,394],{},"Trakthygge är sedan 1950-talet det dominerande skogsskötselsystemet. Det går ut på att skapa likåldriga, större bestånd (trakter), vanligtvis med ett trädslag, och att hela beståndet sköts samtidigt.",[277,396,398],{"icon":397},"i-material-symbols-timeline",[248,399,400],{},"Standardskötseln är: avverkning → markberedning → plantering → röjning → ett par gallringar → åter avverkning efter 60 till 100 år, beroende på bördighet och var i Sverige skogen ligger.",[277,402,404],{"icon":403},"i-ph-farm",[248,405,406],{},"Trakthuggning sker nästan uteslutande med kalavverkning och plantering, alltmer sällsynt med fröträd som avverkas efter plantföryngring skett naturligt.",{"title":164,"searchDepth":252,"depth":252,"links":408},[],"Trakthygge är sedan 1950-talet det dominerande skogsskötselsystemet. Det går ut på att skapa likåldriga, större bestånd (trakter), vanligtvis med ett trädslag, och hela beståndet sköts samtidigt.","i-material-symbols:resize","images/metoder/kalhygge.png",4,{},"trakthygge","Trakthygge","/skogsskotsel/metoder/trakthygge/om_metoden",{"title":243,"description":409},"Kalavverkning med hänsyn","2.skogsskotsel/metoder/4.trakthygge/0.om_metoden","j6T3QUclmgnaajAdHrP_NnEsJ1kQ6uYZ7pmwrf8m3AQ",{"data":422,"body":423},{},{"type":424,"children":425},"root",[426],{"type":427,"tag":248,"props":428,"children":429},"element",{},[430],{"type":431,"value":157},"text",1773935584943]